W2_TECH_BUILDOUT_ID=your_w2_id
W3_ARTIST_ONBOARDING_ID=your_w3_id
W4_PRELAUNCH_MARKETING_ID=your_w4_id
W5_FAN_EXPERIENCE_ID=your_w5_id
W6_ONGOING_OPS_ID=your_w6_id

# Custom Field IDs (retrieve from ClickUp workspace)
ENTITY_FIELD_ID=your_entity_field_id
DRI_FIELD_ID=your_dri_field_id
SLA_FIELD_ID=your_sla_field_id
SLA_DUE_AT_FIELD_ID=your_sla_due_at_field_id
DISPATCHED_AT_FIELD_ID=your_dispatched_at_field_id
DISPATCHED_BY_RULE_FIELD_ID=your_dispatched_by_rule_field_id

